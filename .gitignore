# Python
__pycache__/
*.py[cod]
.pytest_cache/

# Obsidian workspace / session files
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Plugin data files — SENSITIVE (contain tokens or API keys)
# Only exclude plugins that store credentials
.obsidian/plugins/easy-git/data.json
.obsidian/plugins/realclaudian/data.json
.obsidian/plugins/google-calendar/data.json

# Safe plugin data (icons, settings, etc.) — intentionally NOT excluded:
# obsidian-icon-folder/data.json  → stores folder icon assignments
# obsidian-spaced-repetition/data.json → stores SR settings
# pretty-properties/data.json → stores banner/icon config
# agent-client/data.json → stores agent config (no secrets)

# Plugin binaries — large JS files (track manifests only)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Temporary files
*.tmp
*.bak

# Claudian session data (auto-generated)
.claudian/sessions/

# Make.md internal data (large, auto-generated)
.makemd/
.space/
